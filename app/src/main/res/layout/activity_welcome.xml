<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/welcome_bg"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center_horizontal"
        android:padding="28dp">

        <!-- Heart icon -->
        <ImageView
            android:layout_width="140dp"
            android:layout_height="140dp"
            android:layout_marginTop="48dp"
            android:src="@mipmap/ic_launcher"
            android:elevation="8dp" />

        <!-- App name -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="28dp"
            android:text="@string/app_name"
            android:textSize="30sp"
            android:textStyle="bold"
            android:textColor="@color/text_dark"
            android:fontFamily="sans-serif-medium" />

        <!-- Tagline -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:text="تطبيق مراسلة حبيبي"
            android:textSize="15sp"
            android:textColor="@color/pink_primary"
            android:fontFamily="sans-serif" />

        <!-- Description -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:gravity="center"
            android:text="أهلاً بك في تطبيق شات تواصل حبيبي، حيث يتم التواصل بين الأشخاص والحبيب بسهولة وسرعة. تطبيق مراسلة بسيط وآمن يجمعك مع من تحب في مكان واحد."
            android:textSize="14sp"
            android:lineSpacingExtra="4dp"
            android:textColor="@color/text_subtitle"
            android:fontFamily="sans-serif" />

        <!-- Features list card -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:orientation="vertical"
            android:background="@android:color/white"
            android:padding="18dp"
            android:elevation="3dp">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="💬  مراسلات فورية"
                android:textSize="14sp"
                android:textColor="@color/text_dark"
                android:padding="6dp" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="🔒  خاصة وآمنة"
                android:textSize="14sp"
                android:textColor="@color/text_dark"
                android:padding="6dp" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="⚡  سهل وسريع"
                android:textSize="14sp"
                android:textColor="@color/text_dark"
                android:padding="6dp" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="🎁  مجاني تماماً"
                android:textSize="14sp"
                android:textColor="@color/text_dark"
                android:padding="6dp" />
        </LinearLayout>

        <!-- Spacer -->
        <View
            android:layout_width="1dp"
            android:layout_height="0dp"
            android:layout_weight="1" />

        <!-- Start button -->
        <Button
            android:id="@+id/btn_start"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:layout_marginTop="28dp"
            android:layout_marginBottom="32dp"
            android:text="ابدأ الآن"
            android:textSize="18sp"
            android:textStyle="bold"
            android:textColor="@android:color/white"
            android:backgroundTint="@color/pink_primary" />

    </LinearLayout>
</ScrollView>
